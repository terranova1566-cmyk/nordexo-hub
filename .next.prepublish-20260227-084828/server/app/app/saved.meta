{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/saved/layout,_N_T_/app/saved/page,_N_T_/app/saved"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/saved/__PAGE__",
    "/app/saved",
    "/app",
    "/_index",
    "/_head"
  ]
}