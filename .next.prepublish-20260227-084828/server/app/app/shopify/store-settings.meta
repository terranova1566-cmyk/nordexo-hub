{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/shopify/layout,_N_T_/app/shopify/store-settings/layout,_N_T_/app/shopify/store-settings/page,_N_T_/app/shopify/store-settings"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/shopify/store-settings/__PAGE__",
    "/app/shopify/store-settings",
    "/app/shopify",
    "/app",
    "/_index",
    "/_head"
  ]
}