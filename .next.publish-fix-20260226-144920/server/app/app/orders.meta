{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/orders/layout,_N_T_/app/orders/page,_N_T_/app/orders"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/orders/__PAGE__",
    "/app/orders",
    "/app",
    "/_index",
    "/_head"
  ]
}