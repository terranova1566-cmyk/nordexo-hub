{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/exports/layout,_N_T_/app/exports/page,_N_T_/app/exports"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/exports/__PAGE__",
    "/app/exports",
    "/app",
    "/_index",
    "/_head"
  ]
}