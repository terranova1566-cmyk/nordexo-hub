{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/app/layout,_N_T_/app/discovery/layout,_N_T_/app/discovery/page,_N_T_/app/discovery"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/app/discovery/__PAGE__",
    "/app/discovery",
    "/app",
    "/_index",
    "/_head"
  ]
}